[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=7 format=3]

[ext_resource type="Script" path="res://scripts/data/scenario_definition.gd" id="1_scenario"]
[ext_resource type="Resource" path="res://resources/encounters/phase7_fight_01_street_corner.tres" id="2_encounter_a"]
[ext_resource type="Resource" path="res://resources/encounters/catalog_test_rooftop_knives.tres" id="3_encounter_b"]
[ext_resource type="Resource" path="res://resources/encounters/phase7_fight_03_rooftop.tres" id="4_encounter_c"]
[ext_resource type="Resource" path="res://resources/rewards/honed_blade_for_mira.tres" id="5_reward"]
[ext_resource type="Resource" path="res://resources/rewards/catalog_reward_mercy_coin.tres" id="6_reward"]

[resource]
script = ExtResource("1_scenario")
scenario_id = "roadside_ambush"
display_name = "Roadside Ambush"
description = "A short contract that proves the scenario structure."
story_intro = "Bandits have been harassing caravans on the old road."
story_outro = "The road is ugly again, but at least it is open."
party_size = 3
encounters = [ExtResource("2_encounter_a"), ExtResource("3_encounter_b"), ExtResource("4_encounter_c")]
tier = 1
recommended_level_min = 1
recommended_level_max = 2
tags = ["road", "bandits", "starter"]
rewards = [ExtResource("5_reward"), ExtResource("6_reward")]
content_unlocks = ["first_road_bandit_notes"]
