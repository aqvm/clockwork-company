[resource]
script = ExtResource("1_scenario")
scenario_id = "burned_chapel"
display_name = "Burned Chapel"
description = "A compact mission with a future healing/status pressure theme."
story_intro = "A ruined chapel still smolders with hostile rites."
story_outro = "The last cinders gutter out, leaving only ash and questions."
party_size = 3
encounters = [ExtResource("2_encounter_a"), ExtResource("3_encounter_b"), ExtResource("4_encounter_c")]
scenario_rules = [ExtResource("5_rule")]
tier = 2
recommended_level_min = 1
recommended_level_max = 3
tags = ["chapel", "ash", "status"]
rewards = [ExtResource("6_reward"), ExtResource("7_reward")]
content_unlocks = ["ash_chapel_rite_notes"]
