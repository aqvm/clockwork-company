[gd_resource type="Resource" script_class="ScenarioDefinition" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/data/scenario_definition.gd" id="1_scenario"]
[ext_resource type="Resource" path="res://resources/encounters/phase7_fight_01_street_corner.tres" id="2_encounter_a"]
[ext_resource type="Resource" path="res://resources/encounters/catalog_test_debt_office.tres" id="3_encounter_b"]
[ext_resource type="Resource" path="res://resources/encounters/phase7_fight_04_vault_annex.tres" id="4_encounter_c"]
