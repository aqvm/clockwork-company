[gd_resource type="Resource" script_class="JobDefinition" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/data/job_definition.gd" id="1_job"]
[ext_resource type="Script" path="res://scripts/data/skill_definition.gd" id="2_skill"]
[ext_resource type="Script" path="res://scripts/data/passive_definition.gd" id="3_passive"]
[ext_resource type="Script" path="res://scripts/data/reaction_definition.gd" id="4_reaction"]
[ext_resource type="Script" path="res://scripts/data/tactic_definition.gd" id="5_tactic"]

[sub_resource type="Resource" id="Resource_guard_skill"]
script = ExtResource("2_skill")
display_name = "Shield Wall"
tags = ["guard", "skill"]
action = "Guard"
default_target = "Self"
amount_modifier = 1

[sub_resource type="Resource" id="Resource_guard_passive"]
script = ExtResource("3_passive")
display_name = "Guard Training"
tags = ["guard"]
passive_type = "Guard Armor Bonus"
amount = 1
cooldown_turns = 0

[sub_resource type="Resource" id="Resource_guard_reaction"]
script = ExtResource("4_reaction")
display_name = "Hold Fast"
tags = ["low_hp", "reaction"]
trigger = "HP Below Threshold"
condition = "Self HP Below Percent"
reaction_type = "Gain Armor"
amount = 3
threshold_percent = 50
cooldown_turns = 4

[sub_resource type="Resource" id="Resource_guard_default_tactic"]
script = ExtResource("5_tactic")
display_name = "Raise Shield Wall"
tags = ["job_default"]
condition = "Enemy Alive"
action = "Job Skill"
target = "Self"

[resource]
script = ExtResource("1_job")
display_name = "Guard"
max_hp_growth = 2
physical_damage_growth = 0
magic_damage_growth = 0
armor_growth = 1
action_interval_growth = 0
skill = SubResource("Resource_guard_skill")
passive = SubResource("Resource_guard_passive")
reaction = SubResource("Resource_guard_reaction")
default_tactic = SubResource("Resource_guard_default_tactic")
