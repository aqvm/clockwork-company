[gd_resource type="Resource" script_class="JobDefinition" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/data/job_definition.gd" id="1_job"]
[ext_resource type="Script" path="res://scripts/data/skill_definition.gd" id="2_skill"]
[ext_resource type="Script" path="res://scripts/data/passive_definition.gd" id="3_passive"]
[ext_resource type="Script" path="res://scripts/data/reaction_definition.gd" id="4_reaction"]
[ext_resource type="Script" path="res://scripts/data/tactic_definition.gd" id="5_tactic"]

[sub_resource type="Resource" id="Resource_apprentice_skill"]
script = ExtResource("2_skill")
display_name = "Lesson Spark"
tags = ["training", "attack", "magic"]
action = "Attack"
default_target = "Frontmost Enemy"
amount_modifier = 1

[sub_resource type="Resource" id="Resource_apprentice_passive"]
script = ExtResource("3_passive")
display_name = "First Aid"
tags = ["support"]
passive_type = "Heal Bonus"
amount = 2
cooldown_turns = 0

[sub_resource type="Resource" id="Resource_apprentice_reaction"]
script = ExtResource("4_reaction")
display_name = "Panic Lesson"
tags = ["low_hp", "reaction"]
trigger = "HP Below Threshold"
condition = "Self HP Below Percent"
reaction_type = "Heal Self"
amount = 3
threshold_percent = 50
cooldown_turns = 3

[sub_resource type="Resource" id="Resource_apprentice_default_tactic"]
script = ExtResource("5_tactic")
display_name = "Practice Spark"
tags = ["job_default"]
condition = "Enemy Alive"
action = "Job Skill"
target = "Frontmost Enemy"

[resource]
script = ExtResource("1_job")
display_name = "Apprentice"
max_hp_growth = 0
physical_damage_growth = 0
magic_damage_growth = 1
armor_growth = 0
action_interval_growth = -1
skill = SubResource("Resource_apprentice_skill")
passive = SubResource("Resource_apprentice_passive")
reaction = SubResource("Resource_apprentice_reaction")
default_tactic = SubResource("Resource_apprentice_default_tactic")
