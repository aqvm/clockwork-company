[gd_resource type="Resource" script_class="ScenarioRuleDefinition" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/data/scenario_rule_definition.gd" id="1_rule"]
[ext_resource type="Script" path="res://scripts/data/effect_definition.gd" id="2_effect"]
[ext_resource type="Resource" path="res://resources/statuses/confusion.tres" id="3_confusion"]

[sub_resource type="Resource" id="Effect_confusion"]
script = ExtResource("2_effect")
display_name = "Ash-Choked Confusion"
trigger = "Battle Start"
target_selector = "All Units"
effect_type = "Apply Status"
status = ExtResource("3_confusion")
status_is_permanent = true

[resource]
script = ExtResource("1_rule")
rule_id = "ash_chapel_confusion"
display_name = "Ash-Choked Rites"
description = "Every unit permanently has Confusion for each encounter: the first otherwise-valid tactic it would use each turn is skipped."
tags = ["status", "confusion", "ritual"]
effects = Array[ExtResource("2_effect")]([SubResource("Effect_confusion")])
