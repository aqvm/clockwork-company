[ext_resource type="Resource" path="res://resources/jobs/guard.tres" id="2_job"]
[ext_resource type="Resource" path="res://resources/items/reinforced_buckler.tres" id="3_armor"]
[ext_resource type="Resource" path="res://resources/items/horncap.tres" id="helmet_item"]
